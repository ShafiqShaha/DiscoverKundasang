            </div>
        </div>

        <div class="gallery-card">
            <img src="img/gallery/gallery8.jpg" alt="Mountain View">
            <div class="gallery-overlay">
                <h3>Mountain View</h3>
            </div>
        </div>

    </div>

</section>

