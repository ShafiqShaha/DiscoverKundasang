<%
    String pageTitle = "Gallery";
%>

<%@ include file="includes/header.jsp" %>

<section class="gallery-section page-fade-in">

    <div class="gallery-title">
        <h2>Explore <span>Kundasang</span></h2>

        <p>
            Discover the breathtaking beauty of Kundasang through stunning
